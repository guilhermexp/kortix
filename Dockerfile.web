# Dockerfile for Kortix Web (Next.js frontend)
FROM oven/bun:1 AS builder

WORKDIR /app

# Copy package files for better layer caching
COPY package.json bun.lock ./
COPY apps/web/package.json apps/web/
COPY apps/api/package.json apps/api/
COPY apps/api/install-markitdown.sh apps/api/
COPY packages/ packages/

# Install dependencies
RUN bun install

# Copy all source code
COPY . .

# Build args for NEXT_PUBLIC_* (embedded at build time by Next.js)
ARG NEXT_PUBLIC_BACKEND_URL
ARG NEXT_PUBLIC_APP_URL
ARG NEXT_PUBLIC_HOST_ID
ARG NEXT_PUBLIC_MCP_SERVER_URL
ARG NEXT_PUBLIC_DOCS_URL
ARG NEXT_PUBLIC_CANVAS_AGENT_UI_ENABLED
ARG NEXT_PUBLIC_SUPABASE_URL
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY
ARG NEXT_PUBLIC_TELEMETRY_ENABLED
ARG API_INTERNAL_URL
ARG BACKEND_URL_INTERNAL

ENV NODE_ENV=production
ENV NEXT_PUBLIC_BACKEND_URL=$NEXT_PUBLIC_BACKEND_URL
ENV NEXT_PUBLIC_APP_URL=$NEXT_PUBLIC_APP_URL
ENV NEXT_PUBLIC_HOST_ID=$NEXT_PUBLIC_HOST_ID
ENV NEXT_PUBLIC_MCP_SERVER_URL=$NEXT_PUBLIC_MCP_SERVER_URL
ENV NEXT_PUBLIC_DOCS_URL=$NEXT_PUBLIC_DOCS_URL
ENV NEXT_PUBLIC_CANVAS_AGENT_UI_ENABLED=$NEXT_PUBLIC_CANVAS_AGENT_UI_ENABLED
ENV NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL
ENV NEXT_PUBLIC_SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY
ENV NEXT_PUBLIC_TELEMETRY_ENABLED=$NEXT_PUBLIC_TELEMETRY_ENABLED

# Build the Next.js app (standalone output)
RUN cd apps/web && bun run build

# --- Production stage ---
FROM oven/bun:1-slim AS runner

WORKDIR /app

ARG NEXT_PUBLIC_BACKEND_URL
ARG API_INTERNAL_URL
ARG BACKEND_URL_INTERNAL

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ENV NEXT_PUBLIC_BACKEND_URL=$NEXT_PUBLIC_BACKEND_URL
ENV API_INTERNAL_URL=$API_INTERNAL_URL
ENV BACKEND_URL_INTERNAL=$BACKEND_URL_INTERNAL

# Copy standalone build output
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public

EXPOSE 3000

# Next.js standalone server
CMD ["bun", "apps/web/server.js"]
