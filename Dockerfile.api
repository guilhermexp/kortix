# Dockerfile for Kortix API service
FROM oven/bun:1

# Install Python, pip, and Node.js (required by Claude Agent SDK CLI subprocess)
RUN apt-get update && apt-get install -y \
    python3 python3-pip python3-venv gcc \
    curl \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy package files for better caching
COPY package.json bun.lock ./
COPY apps/api/package.json apps/api/
COPY apps/api/install-markitdown.sh apps/api/
COPY apps/web/package.json apps/web/
COPY packages/ packages/

# Install Node dependencies
RUN bun install

# Copy all application code
COPY . .

# Install MarkItDown Python dependencies
RUN bash apps/api/install-markitdown.sh || true

# Create non-root user (Claude Agent SDK refuses --dangerously-skip-permissions as root)
RUN groupadd -r kortix && useradd -r -g kortix -d /app -s /bin/bash kortix \
    && chown -R kortix:kortix /app

# Set environment variables
ENV NODE_ENV=production
ENV MARKITDOWN_PYTHON_PATH=python3
ENV PORT=4000

# Switch to non-root user
USER kortix

# Expose port
EXPOSE 4000

# Start the API server
CMD ["bun", "run", "--cwd", "apps/api", "start"]
